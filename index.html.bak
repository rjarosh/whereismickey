<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Where is Mickey?</title>
  <meta name="description" content="Find when and where WDW Characters are." />
  <style>

    /* make flourish charts expand fully */
  .flourish-embed {
    width: 100% !important;
    height: 100% !important;
  }

    :root{
      --bg:#f7f8fb;
      --card:#ffffff;
      --muted:#6b7280;
      --accent:#2563eb;
      --max-width:1100px;
      --gap:1rem;
      font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
    }
    *{box-sizing:border-box}
    body{margin:0;background:var(--bg);color:#111}
    .wrap{max-width:var(--max-width);margin:0 auto;padding:1rem}

    /* header/nav */
    header{background:linear-gradient(90deg,#ffffff, #fbfdff);border-bottom:1px solid rgba(16,24,40,0.04)}
    .nav{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:0.6rem 1rem}
    .brand{display:flex;gap:.6rem;align-items:center}
    .brand .logo{width:36px;height:36px;background:var(--accent);border-radius:8px;display:inline-block}
    nav ul{list-style:none;margin:0;padding:0;display:flex;gap:0.6rem;align-items:center}
    nav a{color:inherit;text-decoration:none;padding:.4rem .6rem;border-radius:6px}
    nav a:hover{background:rgba(37,99,235,0.08)}

    /* mobile menu */
    .menu-toggle{display:none;border:0;background:transparent;font-size:1.1rem}

    /* hero */
    .hero{padding:1.2rem 0}
    .hero h1{margin:.2rem 0;font-size:1.4rem}
    .hero p{margin:0;color:var(--muted)}

    /* charts stacked */
    .charts{display:flex;flex-direction:column;gap:var(--gap);margin-top:1rem}
    .card{background:var(--card);border-radius:12px;padding:0.6rem;border:1px solid rgba(16,24,40,0.04);box-shadow:0 1px 0 rgba(16,24,40,0.02)}
    .card header{display:flex;align-items:center;justify-content:space-between;padding:0 0.4rem 0.4rem}
    .card h2{margin:0;font-size:1rem}
    .embed{min-height:320px;border-radius:8px;overflow:hidden;background:linear-gradient(180deg,rgba(0,0,0,0.02),transparent);display:flex;align-items:center;justify-content:center}
    .embed iframe{width:100%;height:100%;border:0;min-height:320px}

    /* about */
    .about{margin-top:1.2rem;padding:1rem;background:transparent}

    footer{margin-top:1.6rem;padding:1rem 0;color:var(--muted);font-size:.9rem}

    @media(max-width:520px){
      .brand .text{display:none}
      .menu-toggle{display:inline-block}
      nav{display:none}
      nav.open{display:block;position:absolute;left:0;right:0;top:64px;background:var(--card);padding:0.6rem;border-bottom:1px solid rgba(16,24,40,0.04)}
    }
  </style>
</head>
<body>
  <header>
    <div class="wrap nav">
      <div class="brand">
        <img src="https://api.hub.jhu.edu/factory/sites/default/files/styles/soft_crop_2400/public/2024-01/Mickey_Mouse.jpg" alt="Logo" class="logo">
        <div class="text">
          <strong>Where is Mickey?</strong>
          <div style="font-size:.8rem;color:var(--muted)">Today's Disney World Characters</div>
        </div>
      </div>

      <button class="menu-toggle" id="menuToggle" aria-expanded="false" aria-controls="mainNav">☰</button>

      <nav id="mainNav">
        <ul>
          <li><a href="#home">Home</a></li>
          <li><a href="#about">About</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main class="wrap" id="home">
    <section class="hero">
      <h1>Where and when can I see my favorite Disney World characters?</h1>
      <p>All the data is from the Disney World app, just organized for easy viewing.</p>
    </section>

    <section class="charts" aria-label="Charts">
  <article class="card" id="chartCard1">
    <header>
      <h2>Timeline</h2>
    </header>
    <div class="embed" id="embed1">
      <div class="flourish-embed flourish-gantt" data-src="visualisation/25082814">
        <script src="https://public.flourish.studio/resources/embed.js"></script>
        <noscript>
          <img src="https://public.flourish.studio/visualisation/25082814/thumbnail"
               width="100%" alt="gantt visualization" />
        </noscript>
      </div>
    </div>
  </article>

  <article class="card" id="chartCard2">
    <header>
      <h2>Table</h2>
    </header>
    <iframe title="Disney World Characters" aria-label="Table" id="datawrapper-chart-HmEEe" src="https://datawrapper.dwcdn.net/HmEEe/1/" scrolling="no" frameborder="0" style="width: 0; min-width: 100% !important; border: none;" height="4400" data-external="1"></iframe><script type="text/javascript">!function(){"use strict";window.addEventListener("message",function(a){if(void 0!==a.data["datawrapper-height"]){var e=document.querySelectorAll("iframe");for(var t in a.data["datawrapper-height"])for(var r,i=0;r=e[i];i++)if(r.contentWindow===a.source){var d=a.data["datawrapper-height"][t]+"px";r.style.height=d}}})}();

    
</script>
  </article>
</section>


    <section id="about" class="about">
      <div class="card">
        <header><h2>About</h2></header>
        <div style="padding:0.6rem 0;color:var(--muted);line-height:1.45">
          <strong>What is this page?</strong></br>
          All of this data is on the WDW app, but I wanted to see it more easily and visually so I made this website. 
          
        </div>
      </div>
    </section>

    <footer>
      <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:.5rem;align-items:center">
        <div>Not affiliated with Disney</div>
        <div style="color:var(--muted)">© <span id="year"></span></div>
      </div>
    </footer>
  </main>

  <script>
    document.getElementById('year').textContent = new Date().getFullYear();
    const menuToggle = document.getElementById('menuToggle');
    const mainNav = document.getElementById('mainNav');
    menuToggle && menuToggle.addEventListener('click', () => {
      const open = mainNav.classList.toggle('open');
      menuToggle.setAttribute('aria-expanded', String(open));
    });
  </script>
</body>
</html>
